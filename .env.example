# WorkflowPilot - ET AI Hackathon 2026
# Multi-Agent Enterprise Workflow System Configuration

# Primary LLM API Key - Groq (Llama 3.3 70B)
GROQ_API_KEY=your_groq_api_key_here

# Secondary LLM API Key - Google (Gemini 2.0 Flash)
GOOGLE_API_KEY=your_google_api_key_here

# Application host binding
APP_HOST=0.0.0.0

# Application port
APP_PORT=8000

# Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Path for audit log output
AUDIT_LOG_PATH=./audit_log.jsonl

# Enable error injection for demo purposes (true/false)
ENABLE_ERROR_INJECTION=false

# Enable LLM routing between providers (true/false - set false to use only Groq)
LLM_ROUTING_ENABLED=false
